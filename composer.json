{
  "name": "mikejw/elib-base",
  "type": "library",
  "description": "ELib Base",
  "keywords": [
    "lib"
  ],
  "homepage": "https://empathy.sh",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael J. Whiting",
      "email": "mail@mikejw.co.uk"
    }
  ],
  "require": {
    "mikejw/empathy": "^4",
    "phpmailer/phpmailer": "^6.1.6"
  },
  "require-dev": {
    "phpunit/phpunit": "12.5.14",
    "pestphp/pest": "^4.4",
    "laravel/pint": "dev-main",
    "phpstan/phpstan": "2.2.x-dev"
  },
  "autoload": {
    "psr-0": {
      "Empathy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "scripts": {
    "format": "pint ./src ./tests",
    "format-check": "pint --test ./src ./tests",
    "analyse": "phpstan --memory-limit=1G",
    "test": "pest",
    "test:coverage": "XDEBUG_MODE=coverage pest --coverage-html ./build/coverage",
    "check": [
      "@format-check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
