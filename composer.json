{
  "name": "mikejw/elib-base",
  "type": "library",
  "description": "ELib Base",
  "keywords": [
    "lib"
  ],
  "homepage": "https://empathy.sh",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael J. Whiting",
      "email": "mail@mikejw.co.uk"
    }
  ],
  "require": {
    "mikejw/empathy": "^4",
    "phpmailer/phpmailer": "^6.1.6"
  },
  "require-dev": {
    "phpunit/phpunit": "12.5.14",
    "pestphp/pest": "^4.4"
  },
  "autoload": {
    "psr-0": {
      "Empathy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-0": {
      "Esuite\\": "t/"
    },
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "scripts": {
    "test": "phpunit -c ./t/phpunit.xml",
    "test:coverage": "XDEBUG_MODE=coverage phpunit -c ./t/phpunit.xml --coverage-html ./build/coverage",
    "check": [
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
